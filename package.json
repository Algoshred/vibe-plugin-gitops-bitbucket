{
  "name": "@vibecontrols/vibe-plugin-gitops-bitbucket",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "description": "Bitbucket Cloud provider for VibeControls GitOps meta plugin (REST v2)",
  "engines": {
    "bun": ">=1.3.14"
  },
  "author": {
    "name": "Vignesh T.V",
    "email": "vignesh@burdenoff.com",
    "url": "https://github.com/tvvignesh"
  },
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --minify-syntax --minify-whitespace --external elysia && tsc --emitDeclarationOnly --declaration --outDir ./dist",
    "dev": "tsc --watch",
    "lint": "eslint ./src",
    "lint:sanity": "if [ \"${CI:-}\" = \"true\" ]; then bun run lint; else bun run lint -- --cache --cache-location .eslintcache; fi",
    "format": "bunx prettier . --write",
    "format:check": "bunx prettier . --check",
    "type:check": "tsc --noEmit",
    "test": "bun test",
    "clean": "rimraf dist",
    "prebuild": "bun run clean",
    "prepublishOnly": "bun run build",
    "sanity": "bun run format:check && bun run lint:sanity && bun run type:check && bun run build"
  },
  "dependencies": {
    "@vibecontrols/plugin-sdk": "2026.522.1",
    "elysia": "^1.4.28"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.9",
    "eslint": "^9.30.1",
    "globals": "^17.3.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "peerDependencies": {
    "@vibecontrols/agent": ">=2.0.0",
    "@vibecontrols/vibe-plugin-gitops": ">=0.0.0"
  },
  "peerDependenciesMeta": {
    "@vibecontrols/agent": {
      "optional": true
    },
    "@vibecontrols/vibe-plugin-gitops": {
      "optional": true
    }
  },
  "keywords": [
    "vibecontrols",
    "vibe-plugin",
    "gitops",
    "bitbucket",
    "ci",
    "bun"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/algoshred/vibe-plugin-gitops-bitbucket.git"
  },
  "bugs": {
    "url": "https://github.com/algoshred/vibe-plugin-gitops-bitbucket/issues"
  },
  "homepage": "https://vibecontrols.com",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ]
}
